  "deep_analysis": {
    "instruction": "Produce a concise but substantive briefing for a healthcare regulatory, policy, and consulting audience. Stay grounded in the item; flag uncertainty rather than speculating.",
    "sections": [
      {
        "id": "background",
        "label": "Background",
        "kind": "text",
        "instruction": "Two to three sentences situating this development: the rule, program, enforcement thread, or market trend it belongs to and what preceded it."
      },
      {
        "id": "key_stakeholders",
        "label": "Key stakeholders",
        "kind": "list",
        "instruction": "The agencies, provider types, manufacturers, payers, or patient populations with a material interest. Name them only if supported by the item."
      },
      {
        "id": "scenarios",
        "label": "Scenarios to watch",
        "kind": "list",
        "instruction": "Two or three plausible ways this could develop over the next 6–18 months, each phrased as a short conditional."
      },
      {
        "id": "recommended_actions",
        "label": "Recommended actions",
        "kind": "list",
        "instruction": "Concrete next steps a compliance, policy, or consulting team should consider this week."
      }
    ],
    "deep_batch_size": 6
  },
  "cadence": {
    "cron": "0 7 * * 1",
    "timezone": "America/New_York"
  },
  "cost_caps": {
    "max_items_per_run": 300,
    "max_output_tokens_per_run": 9000000
  },

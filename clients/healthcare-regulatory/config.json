{
  "branding": {
    "name": "Healthcare Regulatory & Market Monitor",
    "accent_color": "#0F766E"
  },
  "editions": [
    {
      "id": "policy",
      "label": "Policy",
      "audience_description": "Government-affairs, regulatory, and health-policy professionals tracking legislation, rulemaking, enforcement, coverage and payment policy, litigation, and oversight.",
      "analysis_instructions": "Prioritise federal legislation and its movement, proposed and final rules, regulatory enforcement actions, coverage and payment policy (Medicare/Medicaid/ACA), litigation that sets precedent, and oversight reports (GAO/CBO/OIG/MedPAC). Flag effective dates, comment deadlines, and statutory triggers. Score pure market/M&A items and routine device-clearance business intelligence low unless they carry a clear policy or regulatory implication.",
      "categories": [
        "Legislation",
        "Rulemaking",
        "Enforcement",
        "Coverage & Payment",
        "Litigation",
        "Oversight & Reports"
      ]
    },
    {
      "id": "consulting",
      "label": "Consulting",
      "audience_description": "Healthcare consultants and corporate strategy/compliance teams tracking enforcement risk to clients, market moves, device and drug clearances, deadlines, and reimbursement impact.",
      "analysis_instructions": "Prioritise developments with direct business implications: enforcement risk to providers/manufacturers/payers, market moves (M&A, partnerships, market entry/exit), device and drug clearances and approvals, compliance and filing deadlines, and changes that shift reimbursement. Quantify dollar and population impact where the source provides it. Score abstract policy commentary lower unless it has concrete operational or commercial consequence.",
      "categories": [
        "Enforcement Risk",
        "Market Moves",
        "Device & Drug Clearances",
        "Deadlines",
        "Reimbursement Impact"
      ]
    }
  ],
  "scoring_rubric": {
    "thresholds": {
      "tier_1_min": 80,
      "tier_2_min": 50,
      "tier_3_min": 20
    },
    "never_discard": [
      "warning letter",
      "consent decree",
      "corporate integrity agreement",
      "import alert",
      "mandatory recall",
      "Class I recall",
      "fraud alert",
      "False Claims Act",
      "qui tam",
      "whistleblower",
      "civil investigative demand",
      "debarment",
      "exclusion",
      "emergency use authorization",
      "public health emergency",
      "immediate jeopardy",
      "civil monetary penalty",
      "DOJ settlement"
    ]
  },
